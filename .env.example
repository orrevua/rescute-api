# Copy to .env and fill in real values. Never commit the real .env.

# Postgres connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://rescute:rescute@localhost:5432/rescute

# REQUIRED. Must be a strong, unique value of at least 32 characters.
# The app refuses to boot if this is unset, empty, or the old "dev-secret-key".
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-strong-random-value-at-least-32-chars

# Set to "production" in deployed environments to drop localhost CORS origins.
ENVIRONMENT=development

# AI provider (OpenAI-compatible Chat Completions API)
AI_PROVIDER_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# Frontend origin allowed by CORS (e.g. the deployed Vercel URL)
FRONTEND_URL=
